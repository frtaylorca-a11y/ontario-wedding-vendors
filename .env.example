# Neon Postgres connection string (used by the app and Drizzle CLI)
DATABASE_URL="postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/ontario_wedding_venues?sslmode=require"

# Anthropic Claude API key (budget planner)
ANTHROPIC_API_KEY=""

# Google Places API key (server-side; used by enrichment scripts)
GOOGLE_PLACES_API_KEY=""

# Public site URL (canonical/OG tags, sitemap)
NEXT_PUBLIC_SITE_URL="https://ontarioweddingvendors.com"

# Public Google Maps key (restricted; used by map embeds where required)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=""

# Analytics — only fire after cookie consent (except Clarity)
NEXT_PUBLIC_GA4_ID=""          # G-XXXXXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=""   # 16-digit Pixel ID
NEXT_PUBLIC_CLARITY_ID=""      # 10-char Clarity project ID (always-on, anonymized)

# OneQR — outbound activation API
ONEQR_API_URL="https://oneqr.events/api/v1"
ONEQR_API_KEY=""

# OneQR — inbound RSVP webhook (shared secret OneQR uses in Authorization
# header when POSTing /api/rsvp/[planId]). If unset, the webhook returns
# 503 and ignores all calls — safe default.
ONEQR_RSVP_WEBHOOK_SECRET=""

# Optional override for the public webhook base URL OneQR should call.
# Defaults to NEXT_PUBLIC_SITE_URL.
# ONEQR_OWV_WEBHOOK_URL="https://ontarioweddingvendors.com"

# Cloudflare R2 — used by scripts/upgrade-vendor-photos.ts (Stage 2 photos)
# and /api/wedding-website/upload-hero (wizard step 3)
CLOUDFLARE_R2_BUCKET=""
CLOUDFLARE_R2_ACCESS_KEY_ID=""
CLOUDFLARE_R2_SECRET_ACCESS_KEY=""
CLOUDFLARE_R2_ENDPOINT=""
CLOUDFLARE_R2_PUBLIC_URL=""

# Brevo transactional email — drives /api/quotes/send-bulk. When unset
# the send-bulk endpoint returns 503 and the /plan/quotes UI surfaces a
# "Email delivery isn't configured" notice on the send step.
BREVO_API_KEY=""
BREVO_SENDER_EMAIL="hello@ontarioweddingvendors.com"
BREVO_SENDER_NAME="Ontario Wedding Vendors"
